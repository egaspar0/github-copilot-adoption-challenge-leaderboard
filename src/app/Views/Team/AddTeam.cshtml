@model LeaderboardApp.Models.Team

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Add Team";
}

<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-center mb-2" style="position:relative;">
        <img id="iconPreviewImg" src="" alt="Icon preview"
             style="width:48px;height:48px;border-radius:50%;display:none;object-fit:cover;border:2px solid #e1e4e8;margin-right:12px;"
             onerror="this.style.display='none';document.getElementById('iconPreviewAvatar').style.display='flex';" />
        <div id="iconPreviewAvatar"
             style="width:48px;height:48px;border-radius:50%;background:#4a90d9;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;font-weight:700;margin-right:12px;">?
        </div>
        <h2 class="mb-0">Spin Up Your Squad</h2>
        <a href="@Url.Action("Profile", "User")" title="Cancel" style="position:absolute;right:0;color:#dc3545;font-size:1.6rem;line-height:1;text-decoration:none;" aria-label="Cancel">&times;</a>
    </div>

    <div class="alert alert-info mt-4">
        <strong>Heads up, code champ!</strong><br />
        🛡️ You can only add teams before the challenge kicks off.<br />
        ✍️ Once you hit <em>Create Team</em>, your team name, tagline, and icon are set in (virtual) stone.<br />
        🛠️ Want to change something later? You’ll need to either create a fresh team or charm an admin to do it for you.<br />
        So pick a name that slaps, a tagline that talks, and an icon that pops! This is your brand, your crew, your vibe!
    </div>

    <!-- Alert message container -->
    <div id="teamMessage" class="alert" style="display:none;"></div>

    <form id="addTeamForm" class="form-horizontal mt-4">
        <div class="form-group">
            <label for="Name" class="control-label col-md-2">Team Name</label>
            <div class="col-md-10">
                <input id="Name" name="Name" class="form-control" placeholder="E.g. Stack Tracers, Null Terminators, Merge Conflict" />
                <span class="text-danger" id="nameValidation"></span>
            </div>
        </div>

        <div class="form-group">
            <label for="Tagline" class="control-label col-md-2">Tagline</label>
            <div class="col-md-10">
                <input id="Tagline" name="Tagline" class="form-control" placeholder="E.g. 'Ship Happens', '404: Limits Not Found', 'We push to prod on Fridays'" />
                <span class="text-danger" id="taglineValidation"></span>
            </div>
        </div>

        <div class="form-group">
            <label for="Icon" class="control-label col-md-2">Team Icon URL <span class="text-muted" style="font-weight:400;">(optional)</span></label>
            <div class="col-md-10">
                <input id="Icon" name="Icon" class="form-control" placeholder="Optional: paste a https:// URL to a .jpg/.png/.svg icon — leave blank for a letter avatar" />
                <span class="text-danger" id="iconValidation"></span>
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="button" id="saveTeamBtn" class="btn btn-success">🎯 Create Team</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#saveTeamBtn').click(function () {
                const name = $('#Name').val().trim();
                const icon = $('#Icon').val().trim();
                const tagline = $('#Tagline').val().trim();

                let isValid = true;
                $('#nameValidation, #iconValidation, #taglineValidation').text("");

                if (!name) {
                    $('#nameValidation').text("Team name is required.");
                    isValid = false;
                }

                if (icon && !isValidURL(icon)) {
                    $('#iconValidation').text("If provided, the icon must be a valid URL (https://...).");
                    isValid = false;
                }

                if (!tagline) {
                    $('#taglineValidation').text("Tagline is required.");
                    isValid = false;
                }

                if (!isValid) return;

                const formData = { Name: name, Icon: icon || null, Tagline: tagline };

                $.ajax({
                    url: '@Url.Action("AddTeam", "Team")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        $('#teamMessage').removeClass('alert-danger').addClass('alert-success')
                            .html("✅ <strong>Success!</strong> Team created. Redirecting to your profile in 3...2...1...")
                            .show();

                        setTimeout(function () {
                            window.location.href = '@Url.Action("Profile", "User")';
                        }, 3000);
                    },
                    error: function (xhr) {
                        const msg = xhr.responseText || xhr.statusText || 'Unknown error';
                        $('#teamMessage').removeClass('alert-success').addClass('alert-danger')
                            .html('🚫 <strong>Something went wrong:</strong> ' + msg)
                            .show();
                    }
                });
            });

            // URL validation helper
            function isValidURL(str) {
                const pattern = new RegExp('^(https?:\\/\\/)' + // protocol
                    '((([a-zA-Z0-9\\-]+\\.)+[a-zA-Z]{2,})|localhost)' + // domain name
                    '(\\:[0-9]+)?(\\/.*)?$', 'i'); // optional port & path
                return !!pattern.test(str);
            }
            // ── Live icon preview ──────────────────────────────────────────
            function getInitials(name) {
                if (!name) return '?';
                var parts = name.trim().split(/\s+/);
                return parts.length >= 2
                    ? (parts[0][0] + parts[1][0]).toUpperCase()
                    : name.substring(0, 2).toUpperCase();
            }
            function getAvatarColor(name) {
                var colors = ['#4a90d9','#7b68ee','#20b2aa','#ff6b6b','#ffa500','#2e8b57','#9370db','#cd853f'];
                if (!name) return colors[0];
                var h = 0;
                for (var i = 0; i < name.length; i++) h = (h + name.charCodeAt(i)) & 0x7fffffff;
                return colors[h % colors.length];
            }
            function updateIconPreview() {
                var url  = $('#Icon').val().trim();
                var name = $('#Name').val().trim();
                var initials = getInitials(name);
                var color    = getAvatarColor(name);
                $('#iconPreviewAvatar').text(initials).css('background', color);
                if (url && isValidURL(url)) {
                    $('#iconPreviewImg').attr('src', url).show();
                    $('#iconPreviewAvatar').hide();
                } else {
                    $('#iconPreviewImg').hide().attr('src', '');
                    $('#iconPreviewAvatar').css('display', 'flex').show();
                }
            }

            var _iconTimer = null;
            $('#Icon').on('input', function () {
                clearTimeout(_iconTimer);
                _iconTimer = setTimeout(updateIconPreview, 500);
            });
            $('#Name').on('input', updateIconPreview);
            updateIconPreview();        });
    </script>
}

